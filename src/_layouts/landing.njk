<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Ionrift Workshop") }}</title>
    <meta name="description" content="{{ description | default("Ionrift Workshop builds GM tools for tabletop RPGs - rest systems, soundscapes, settlement generation, inventory management. Less bookkeeping, more story.") }}">
    <meta name="theme-color" content="#14141e">

    <link rel="icon" href="/img/favicon-48.png" type="image/png" sizes="48x48">
    <link rel="icon" href="/img/favicon-180.png" type="image/png" sizes="180x180">
    <link rel="apple-touch-icon" href="/img/favicon-180.png">

    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ ogTitle | default(title) | default("Ionrift Workshop") }}">
    <meta property="og:description" content="{{ ogDescription | default("GM tools that handle the mechanical overhead - rest systems, soundscapes, settlement generation, inventory management. Built for Foundry VTT, with standalone tools on the way.") }}">
    <meta property="og:url" content="{{ site.url }}">
    <meta property="og:site_name" content="Ionrift Workshop">
    <meta property="og:locale" content="en_GB">

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ ogTitle | default(title) | default("Ionrift Workshop") }}">
    <meta name="twitter:description" content="{{ twitterDescription | default("GM tools for tabletop RPGs. Less bookkeeping, more story.") }}">

    <link rel="canonical" href="{{ site.url }}">

    <meta name="robots" content="index, follow">
    <meta name="keywords" content="foundry vtt, foundry vtt modules, ttrpg tools, gm tools, rest module, soundscape module, settlement generator, tabletop rpg">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Ionrift Workshop",
        "url": "{{ site.url }}",
        "description": "GM tools for tabletop RPGs - rest systems, soundscapes, settlement generation, inventory management.",
        "applicationCategory": "GameApplication",
        "operatingSystem": "Web",
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
        },
        "author": {
            "@type": "Organization",
            "name": "Ionrift Workshop",
            "url": "{{ site.url }}"
        }
    }
    </script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-65B9N0FZC0"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-65B9N0FZC0');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body>

    <div class="atmosphere"></div>
    <div class="noise"></div>

    <div class="wrapper">
        {{ content | safe }}
    </div>

    {% include "landing/scripts.njk" %}
</body>
</html>
