---
layout: landing.njk
pagination:
  data: collections.moduleDetails
  size: 1
  alias: module
permalink: "/modules/{{ module.id }}/"
eleventyComputed:
  title: "{{ module.name }} | Ionrift Workshop"
  description: "{{ module.description }}"
  canonical: "{{ site.url }}/modules/{{ module.id }}/"
  ogTitle: "{{ module.name }}"
  ogDescription: "{{ module.description }}"
  ogImage: "{{ site.url }}{{ module.icon }}"
  bodyClass: "page-module-detail"
---

{% include "landing/nav.njk" %}

<main class="page-main module-detail">
    <div class="container">
        <nav class="page-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">/</span>
            <a href="/#modules">Modules</a>
            <span aria-hidden="true">/</span>
            <span>{{ module.name }}</span>
        </nav>

        <header class="module-detail-header" style="--module-color: {{ module.accent }}; --module-icon-color: {{ module.iconAccent or module.accent }};">
            <div class="module-detail-icon">
                <img src="{{ module.icon }}" alt="">
            </div>
            <div class="module-detail-intro">
                <div class="module-detail-pills">
{% set pillClass = "pill-released" %}
{% set pillText = "Released" %}
{% if module.status == "ea" %}{% set pillClass = "pill-ea" %}{% set pillText = "Early Access" %}{% endif %}
{% if module.status == "ga" %}{% set pillText = "Released" %}{% endif %}
                    <span class="module-pill {{ pillClass }}">{{ pillText }}</span>
{% if module.accessLabel %}
                    <span class="module-pill pill-premium">{{ module.accessLabel }}</span>
{% endif %}
                </div>
                <h1 class="module-detail-title">{{ module.name }}</h1>
                <p class="module-detail-tag" style="color: {{ module.accent }};">{{ module.tagline }}</p>
{% if module.systems and module.systems.length %}
                <div class="module-systems">
{% for s in module.systems %}
                    <span class="module-system">{{ s | systemLabel }}</span>
{% endfor %}
                </div>
{% endif %}
            </div>
        </header>

        <div class="module-trailer">
{% if module.trailer %}
            <div class="module-trailer-embed">
                <iframe
                    src="https://www.youtube-nocookie.com/embed/{{ module.trailer }}"
                    title="{{ module.name }} trailer"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                ></iframe>
            </div>
{% elif module.preview %}
            <figure class="module-trailer-preview">
                <div class="module-trailer-preview-label">Preview</div>
                <div class="module-trailer-preview-frame">
                    <img src="{{ module.preview }}" alt="{{ module.previewAlt or (module.name + ' preview') }}" loading="lazy">
                </div>
{% if module.previewCaption %}
                <figcaption class="module-trailer-preview-caption">{{ module.previewCaption }}</figcaption>
{% endif %}
            </figure>
{% else %}
            <div class="module-trailer-placeholder">
                <span>Trailer coming soon</span>
            </div>
{% endif %}
        </div>

        <div class="module-detail-body ionrift-window">
            <p class="module-detail-lead">{{ module.description }}</p>

{% if module.detailBody and module.detailBody.length %}
            <div class="module-detail-copy">
{% for para in module.detailBody %}
                <p>{{ para }}</p>
{% endfor %}
            </div>
{% endif %}

{% if module.highlights and module.highlights.length %}
            <div class="module-highlights">
{% for h in module.highlights %}
                <span class="module-chip">{{ h }}</span>
{% endfor %}
            </div>
{% endif %}

            <div class="module-detail-actions">
{% if module.install and module.install.method == "foundry" %}
                <a href="{{ module.links.foundryPackage }}" target="_blank" rel="noopener" class="btn btn-ghost module-detail-cta">
                    <img src="/img/fvtt-anvil.png" alt="" class="fvtt-btn-icon">
                    {{ module.install.label }}
                </a>
{% if module.links.github %}
                <a href="{{ module.links.github }}" target="_blank" rel="noopener" class="btn btn-ghost module-detail-cta module-detail-cta--github">
                    <svg class="module-detail-icon-inline" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
                    GitHub
                </a>
{% endif %}
{% elif module.install and module.install.method == "patreon-cloud" %}
                <a href="{{ module.links.patreon }}" target="_blank" rel="noopener" class="btn btn-patreon module-detail-cta">
                    {{ module.install.label }}
                </a>
{% endif %}
{% if module.try %}
                <a href="{{ module.try.href }}" class="btn btn-primary module-detail-cta">{{ module.try.label }}</a>
{% endif %}
            </div>

{% if module.install and module.install.method == "patreon-cloud" %}
            <p class="module-install-note">Subscribe on Patreon, then open the Patreon Library in Ionrift Library and install from there. Not listed in the public Foundry browser.</p>
{% elif module.install and module.install.method == "foundry" %}
            <p class="module-install-note">Install from the <a href="{{ module.links.foundryPackage }}" target="_blank" rel="noopener">Foundry package page</a>, or grab the manifest from <a href="{{ module.links.github }}" target="_blank" rel="noopener">GitHub</a>.</p>
{% endif %}
        </div>

        <p class="page-back">
            <a href="/#modules">&larr; All modules</a>
        </p>
    </div>
</main>

{% include "landing/footer.njk" %}
