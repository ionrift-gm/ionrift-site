<!-- ═══ Modules ═══ -->
        <section class="section" id="modules">
            <div class="container">
                <div class="section-header">
                    <div class="section-label">Foundry VTT Modules</div>
                    <h2 class="section-title">What we build</h2>
                </div>

                <div class="module-hero-grid">
{% for m in catalogue.hero %}
                    <a href="/modules/{{ m.id }}/" class="module-card module-card--hero" style="--module-color: {{ m.accent }};" id="mod-{{ m.id }}-hero">
                        <div class="module-card-hero-top">
                            <div class="module-icon"><img src="{{ m.icon }}" alt=""></div>
                            <div class="module-card-hero-meta">
                                <div class="module-name">{{ m.name }}</div>
                                <div class="module-tag" style="color: {{ m.accent }};">{{ m.tagline }}</div>
                            </div>
                            <span class="module-pill pill-released">Released</span>
                        </div>
                        <p class="module-desc">{{ m.description }}</p>
{% if m.highlights and m.highlights.length %}
                        <div class="module-highlights">
{% for h in m.highlights %}
                            <span class="module-chip">{{ h }}</span>
{% endfor %}
                        </div>
{% endif %}
                        <span class="module-card-cta">View module &rarr;</span>
                    </a>
{% endfor %}
                </div>

{% if catalogue.compact.length %}
                <div class="module-compact-grid">
{% for m in catalogue.compact %}
{% set pillClass = "pill-released" %}
{% set pillText = "Released" %}
{% if m.status == "ea" %}{% set pillClass = "pill-ea" %}{% set pillText = "Early Access" %}{% endif %}
{% if m.status == "ga" %}{% set pillText = "Released" %}{% endif %}
                    <a href="/modules/{{ m.id }}/" class="module-card module-card--compact" style="--module-color: {{ m.accent }};" id="mod-{{ m.id }}-compact">
                        <div class="module-icon module-icon--sm"><img src="{{ m.icon }}" alt=""></div>
                        <div class="module-compact-body">
                            <div class="module-compact-head">
                                <span class="module-compact-name">{{ m.name }}</span>
                                <span class="module-compact-tag" style="color: {{ m.accent }};">{{ m.tagline }}</span>
                            </div>
                            <p class="module-compact-desc">{{ m.description }}</p>
                        </div>
                        <div class="module-compact-pills">
                            <span class="module-pill {{ pillClass }}">{{ pillText }}</span>
{% if m.accessLabel %}
                            <span class="module-pill pill-premium">{{ m.accessLabel }}</span>
{% endif %}
                        </div>
                    </a>
{% endfor %}
                </div>
{% endif %}

{% if catalogue.roadmap.length %}
                <div class="module-roadmap">
                    <p class="module-roadmap-label">In the workshop</p>
                    <div class="module-roadmap-row">
{% for m in catalogue.roadmap %}
                        <div class="module-card module-card--roadmap" style="--module-color: {{ m.accent }};">
                            <div class="module-icon module-icon--sm"><img src="{{ m.icon }}" alt=""></div>
                            <span class="module-roadmap-name">{{ m.name }}</span>
                            <span class="module-pill pill-dev">{{ m.pillLabel | default("Coming soon") }}</span>
                        </div>
{% endfor %}
                    </div>
                </div>
{% endif %}
            </div>
        </section>
