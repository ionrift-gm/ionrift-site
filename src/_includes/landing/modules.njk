<!-- ═══ Modules ═══ -->
        <section class="section" id="modules">
            <div class="container">
                <div class="section-header">
                    <div class="section-label">Foundry VTT Modules</div>
                    <h2 class="section-title">What we build</h2>
                </div>
                <div class="module-grid">
{% for m in modules %}
{% set pillClass = "pill-released" %}
{% set pillText = "Released" %}
{% if m.status == "ea" %}{% set pillClass = "pill-ea" %}{% set pillText = "Early Access" %}{% endif %}
{% if m.status == "roadmap" %}{% set pillClass = "pill-dev" %}{% set pillText = "Roadmap" %}{% endif %}
{% if m.pillLabel %}{% set pillText = m.pillLabel %}{% endif %}
                    <div class="module-card{% if m.status == 'roadmap' %} module-card--soon{% endif %}" style="--module-color: {{ m.accent }};">
                        <div class="module-icon" style="background: {{ m.accent }}14; border-color: {{ m.accent }}26;"><img src="{{ m.icon }}" alt="{{ m.name }}"></div>
                        <div class="module-name">{{ m.name }}</div>
                        <div class="module-tag" style="color: {{ m.accent }};">{{ m.tagline }}</div>
                        <p class="module-desc">{{ m.description }}</p>
                        <div class="module-footer">
                            <div class="module-links-row">
{% if m.install.method == "foundry" %}
                                <a href="{{ m.links.github }}" target="_blank" rel="noopener" class="module-cta" id="mod-{{ m.id }}-foundry">
                                    <img src="/img/fvtt-anvil.png" alt="" class="fvtt-btn-icon">
                                    {{ m.install.label }}
                                </a>
{% elif m.install.method == "patreon-cloud" %}
                                <a href="{{ m.links.patreon }}" target="_blank" rel="noopener" class="module-cta" id="mod-{{ m.id }}-patreon">
                                    {{ m.install.label }}
                                </a>
{% endif %}
{% if m.try %}
                                <a href="{{ m.try.href }}" class="module-try" id="mod-{{ m.id }}-try">{{ m.try.label }} &rarr;</a>
{% endif %}
                            </div>
                            <div class="module-pill-row">
                                <span class="module-pill {{ pillClass }}">{{ pillText }}</span>
{% if m.accessLabel %}
                                <span class="module-pill pill-premium">{{ m.accessLabel }}</span>
{% endif %}
                            </div>
                        </div>
                    </div>
{% endfor %}
                </div>
            </div>
        </section>
