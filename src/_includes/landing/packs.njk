<!-- ═══ Content packs ═══ -->
        <section class="section section-packs" id="packs">
            <div class="container">
                <div class="section-header">
                    <div class="section-label">Content packs</div>
                    <h2 class="section-title">Overlays for the table</h2>
                    <p class="section-lead">Compendium overlays that extend the free modules with recipes, terrain events, loot tables, and sound. One subscription unlocks the library; install from the in-game pack manager.</p>
                </div>

                <div class="pack-how">
                    <div class="pack-how-step">
                        <span class="pack-how-num">1</span>
                        <span>Subscribe on Patreon</span>
                    </div>
                    <div class="pack-how-step">
                        <span class="pack-how-num">2</span>
                        <span>Open the pack manager in Foundry</span>
                    </div>
                    <div class="pack-how-step">
                        <span class="pack-how-num">3</span>
                        <span>Install overlays for the modules you run</span>
                    </div>
                </div>

                <div class="pack-grid">
{% for pack in packs %}
                    <div class="pack-card">
                        <div class="pack-card-top">
                            <h3 class="pack-name">{{ pack.name }}</h3>
                            <span class="pack-tier pack-tier--{{ pack.tier | lower }}">{{ pack.tier }}</span>
                        </div>
                        <p class="pack-desc">{{ pack.description }}</p>
                        <div class="pack-modules">
{% for mod in pack.modules %}
                            <span class="pack-module-tag">{{ mod }}</span>
{% endfor %}
                        </div>
                    </div>
{% endfor %}
                </div>

                <div class="pack-footer">
                    <p class="pack-footer-note">More packs ship with module updates. Keep what you install, even if you cancel.</p>
                    <a href="https://www.patreon.com/c/Ionrift" target="_blank" rel="noopener" class="btn btn-primary">Browse the Patreon library</a>
                </div>
            </div>
        </section>
