<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Soundboard - Ionrift</title>
<meta name="description" content="Free TTRPG soundboard. Crit/fumble stingers, weapon hits, PC voices, and Daggerheart fear/hope sounds.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0d14;--surface:#11111c;--surface2:#181828;--surface3:#1e1e30;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.04);
  --accent:#8b5cf6;--accent-dim:rgba(139,92,246,0.12);--accent-border:rgba(139,92,246,0.35);
  --text:#e2e2f0;--text-muted:rgba(255,255,255,0.35);--text-dim:#888;
  --gold:#c8a040;--green:#3cb371;--red:#e05555;--blue:#4a9eff;
  --dh-fear:#c44;--dh-hope:#5a9;--dh-stress:#b06;--radius:6px;
}
html,body{min-height:100%;background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;font-size:13px;line-height:1.5}

/* Nav */
.nav{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;background:rgba(13,13,20,0.95);border-bottom:1px solid var(--border);backdrop-filter:blur(8px);position:sticky;top:0;z-index:50}
.nav-brand{display:flex;align-items:center;gap:8px;text-decoration:none;color:var(--text);font-weight:700;font-size:14px}
.nav-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px var(--accent)}
.nav-back{font-size:12px;color:var(--text-muted);text-decoration:none}
.nav-back:hover{color:var(--accent)}

/* Wrap */
.page{max-width:1200px;margin:0 auto;padding:20px 16px 60px}

/* Header */
.page-header{margin-bottom:24px}
.page-title{font-size:22px;font-weight:700;letter-spacing:-0.3px;margin-bottom:4px}
.page-sub{font-size:13px;color:var(--text-muted)}

/* System toggle */
.sys-toggle{display:flex;align-items:center;gap:0;background:var(--surface2);border:1px solid var(--border);border-radius:8px;overflow:hidden;width:fit-content;margin-bottom:24px}
.sys-btn{padding:7px 20px;font-size:12px;font-weight:600;font-family:inherit;background:none;border:none;color:var(--text-muted);cursor:pointer;letter-spacing:0.4px;transition:all 0.15s;position:relative}
.sys-btn.active{background:var(--accent-dim);color:#c4b5fd;border-color:var(--accent-border)}
.sys-btn:first-child{border-right:1px solid var(--border)}

/* Master controls */
.master-bar{display:flex;align-items:center;gap:10px;margin-bottom:20px;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius)}
.master-label{font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.8px}
.vol-slider{-webkit-appearance:none;appearance:none;width:120px;height:4px;border-radius:2px;background:var(--surface3);outline:none;cursor:pointer}
.vol-slider::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--accent);cursor:pointer}
.btn-stop-all{margin-left:auto;padding:5px 14px;background:rgba(224,85,85,0.15);border:1px solid rgba(224,85,85,0.3);color:#e05555;border-radius:var(--radius);font-size:12px;font-family:inherit;cursor:pointer;transition:all 0.15s}
.btn-stop-all:hover{background:rgba(224,85,85,0.25)}

/* Section */
.sb-section{margin-bottom:28px}
.sb-section-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);padding:0 2px;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.sb-section-label::after{content:'';flex:1;height:1px;background:var(--border)}

/* Sound grid */
.sb-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px}

/* Sound button */
.sb-btn{
  position:relative;display:flex;flex-direction:column;align-items:flex-start;
  padding:12px 14px 10px;
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  cursor:pointer;font-family:inherit;text-align:left;
  transition:border-color 0.15s,background 0.15s,transform 0.08s;
  overflow:hidden;
}
.sb-btn:hover{border-color:rgba(255,255,255,0.15);background:var(--surface2)}
.sb-btn:active{transform:scale(0.97)}
.sb-btn.playing{border-color:var(--btn-color,var(--accent));background:rgba(var(--btn-rgb,139,92,246),0.12)}
.sb-btn.playing .sb-play-ring{opacity:1}

.sb-icon{font-size:20px;margin-bottom:6px;line-height:1}
.sb-art{width:36px;height:36px;object-fit:contain;margin-bottom:6px;border-radius:4px;filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));pointer-events:none}
.sb-name{font-size:12px;font-weight:600;color:var(--text);line-height:1.3}
.sb-meta{font-size:10px;color:var(--text-dim);margin-top:2px}
.sb-tag{
  position:absolute;top:8px;right:8px;
  font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px;
  text-transform:uppercase;letter-spacing:0.5px;
}

/* Progress bar at bottom of button */
.sb-progress{
  position:absolute;bottom:0;left:0;right:0;height:2px;
  background:var(--btn-color,var(--accent));
  transform-origin:left;transform:scaleX(0);
  transition:transform linear;
  opacity:0.6;
}
.sb-btn.playing .sb-progress{opacity:1}

/* Play ring pulse */
.sb-play-ring{
  position:absolute;inset:0;border-radius:var(--radius);
  box-shadow:0 0 0 2px var(--btn-color,var(--accent)) inset;
  opacity:0;transition:opacity 0.15s;pointer-events:none;
}

/* Category colour overrides */
.sb-btn[data-cat="crit"]{--btn-color:#f59e0b;--btn-rgb:245,158,11}
.sb-btn[data-cat="fumble"]{--btn-color:#e05555;--btn-rgb:224,85,85}
.sb-btn[data-cat="weapon"]{--btn-color:#6b9fd4;--btn-rgb:107,159,212}
.sb-btn[data-cat="combat"]{--btn-color:#9b59b6;--btn-rgb:155,89,182}
.sb-btn[data-cat="voice"]{--btn-color:#e8a87c;--btn-rgb:232,168,124}
.sb-btn[data-cat="fear"]{--btn-color:#cc4444;--btn-rgb:204,68,68}
.sb-btn[data-cat="hope"]{--btn-color:#55aa88;--btn-rgb:85,170,136}
.sb-btn[data-cat="stress"]{--btn-color:#b066cc;--btn-rgb:176,102,204}
.sb-btn[data-cat="success"]{--btn-color:#5a9eff;--btn-rgb:90,158,255}

/* DH-only sections hidden by default */
.dh-only{display:none}
body.mode-dh .dh-only{display:block}
body.mode-dh .sys-btn[data-sys="dnd"].active,
body.mode-std .sys-btn[data-sys="dh"].active{background:none;color:var(--text-muted)}
body.mode-dh .sys-btn[data-sys="dh"]{background:var(--accent-dim);color:#c4b5fd}
body.mode-std .sys-btn[data-sys="dnd"]{background:var(--accent-dim);color:#c4b5fd}

/* Attribution */
.attribution{margin-top:40px;font-size:10px;color:var(--text-muted);border-top:1px solid var(--border2);padding-top:12px;line-height:1.6}

/* Responsive */
@media(max-width:600px){.sb-grid{grid-template-columns:repeat(auto-fill,minmax(130px,1fr))}}
</style>
</head>
