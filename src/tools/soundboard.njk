<script type="module">
// ── Sound pools ───────────────────────────────────────────────
const BASE = '/audio/sfx';
const POOLS = {
  'stingers/crit':        range('stingers/crit/ROLL_CRIT_', 1, 5),
  'stingers/fumble':      range('stingers/fumble/ROLL_FUMBLE_', 1, 5),
  'stingers/hope_gain':   range('stingers/hope_gain/DAGGERHEART_HOPE_', 1, 6),
  'stingers/hope_use':    range('stingers/hope_use/DAGGERHEART_HOPE_USE_', 1, 6),
  'stingers/fear_gain':   range('stingers/fear_gain/DAGGERHEART_FEAR_', 1, 6),
  'stingers/fear_use_small': range('stingers/fear_use/DAGGERHEART_FEAR_USE_SMALL_', 1, 5),
  'stingers/fear_use_med':   range('stingers/fear_use/DAGGERHEART_FEAR_USE_MED_', 6, 10),
  'stingers/fear_use_large': range('stingers/fear_use/DAGGERHEART_FEAR_USE_LARGE_', 11, 17),
  'stingers/stress':      range('stingers/stress/DAGGERHEART_STRESS_', 1, 5),
  'stingers/success':     range('stingers/success/DAGGERHEART_SUCCESS_', 1, 5),
  'weapons/bow':          range('weapons/ATTACK_BOW_FIRE_', 1, 5),
  'weapons/crossbow':     range('weapons/ATTACK_CROSSBOW_', 1, 5),
  'weapons/sword':        range('weapons/ATTACK_SWORD_SLASH_', 1, 5),
  'combat/hit':           range('combat/CORE_HIT_0', 1, 5),
  'combat/miss':          range('combat/CORE_MISS_0', 1, 5),
  'pc/pain-masc':         range('pc/CORE_PAIN_MASCULINE_0', 1, 5),
  'pc/pain-fem':          range('pc/CORE_PAIN_FEMININE_0', 1, 8),
  'pc/death-masc':        range('pc/CORE_DEATH_MASCULINE_0', 1, 5),
  'pc/death-fem':         range('pc/CORE_DEATH_FEMININE_0', 1, 5),
};

function range(prefix, from, to) {
  const out = [];
  for (let i = from; i <= to; i++) {
    out.push(`${BASE}/${prefix}${String(i).padStart(2, '0')}.mp3`);
  }
  return out;
}

// ── Playback state ────────────────────────────────────────────
let masterVol = 0.8;
const activeAudio = new Map(); // btn id → Audio

function pickRandom(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

function playPool(btnId, poolKey) {
  const pool = POOLS[poolKey];
  if (!pool?.length) { console.warn('No pool for', poolKey); return; }
  const src = pickRandom(pool);
  stopBtn(btnId);
  const audio = new Audio(src);
  audio.volume = masterVol;
  audio.play().catch(e => console.error('Audio play failed:', e));
  activeAudio.set(btnId, audio);
  const btn = document.getElementById(btnId);
  btn?.classList.add('playing');
  // Progress bar
  const prog = btn?.querySelector('.sb-progress');
  audio.addEventListener('loadedmetadata', () => {
    if (prog && audio.duration) {
      prog.style.transitionDuration = audio.duration + 's';
      // Trigger reflow then animate
      requestAnimationFrame(() => requestAnimationFrame(() => {
        prog.style.transform = 'scaleX(1)';
      }));
    }
  });
  audio.addEventListener('ended', () => stopBtn(btnId));
}

function stopBtn(btnId) {
  const audio = activeAudio.get(btnId);
  if (audio) { audio.pause(); audio.currentTime = 0; activeAudio.delete(btnId); }
  const btn = document.getElementById(btnId);
  btn?.classList.remove('playing');
  const prog = btn?.querySelector('.sb-progress');
  if (prog) { prog.style.transition = 'none'; prog.style.transform = 'scaleX(0)'; }
}

function stopAll() {
  for (const id of [...activeAudio.keys()]) stopBtn(id);
}

// ── Wire up buttons ───────────────────────────────────────────
document.querySelectorAll('.sb-btn[data-pool]').forEach(btn => {
  btn.addEventListener('click', () => {
    if (btn.classList.contains('playing')) { stopBtn(btn.id); return; }
    playPool(btn.id, btn.dataset.pool);
  });
});

document.getElementById('master-vol').addEventListener('input', e => {
  masterVol = Number(e.target.value);
  for (const audio of activeAudio.values()) audio.volume = masterVol;
});

document.getElementById('btn-stop-all').addEventListener('click', stopAll);

// ── System toggle ─────────────────────────────────────────────
document.querySelectorAll('.sys-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.sys-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.body.className = btn.dataset.sys === 'dh' ? 'mode-dh' : 'mode-std';
    stopAll();
  });
});
